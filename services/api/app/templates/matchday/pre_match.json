{
  "name": "Pre-Match Announcement",
  "description": "Announces an upcoming match with opponent details, date, time, venue, and competition info. Designed to build anticipation and drive ticket sales.",
  "platforms": ["instagram", "facebook", "tiktok", "twitter"],
  "format_type": "image",
  "aspect_ratio": "1:1",
  "brand": {
    "primary_color": "#0057A8",
    "accent_color": "#00A8E8",
    "background": "#0A0E1A",
    "font_headline": "Bebas Neue",
    "font_body": "Barlow Condensed",
    "logo_position": "top-right"
  },
  "layout": {
    "hero_image": true,
    "text_position": "bottom-center",
    "overlay_opacity": 0.65,
    "elements": ["hero_image", "competition_badge", "club_crests", "vs_divider", "match_date", "venue", "headline", "cta_button", "logo"]
  },
  "placeholders": {
    "headline": {"max_chars": 30, "example": "MATCHDAY INCOMING"},
    "opponent_name": {"max_chars": 30, "example": "HNK Hajduk Split"},
    "match_date": {"max_chars": 25, "example": "Saturday, 15 March 2026"},
    "match_time": {"max_chars": 10, "example": "20:00 CET"},
    "venue": {"max_chars": 40, "example": "Main Venue, Zagreb"},
    "competition": {"max_chars": 30, "example": "Industry League Round 24"},
    "cta": {"example": "Get Tickets"}
  },
  "guidelines": "Use a dramatic stadium or player action shot as the hero image. Both club crests should be prominently displayed with a VS divider. Match date and venue must be clearly readable. Always include competition branding. Ensure Demo Brand crest is on the left side."
}
