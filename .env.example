# =============================================================================
# DINAMO MARKETING PLATFORM - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values

# --- Database ---
DATABASE_URL=postgresql+asyncpg://dinamo:dinamo@localhost:5433/dinamo_marketing
DATABASE_URL_SYNC=postgresql://dinamo:dinamo@localhost:5433/dinamo_marketing
POSTGRES_USER=dinamo
POSTGRES_PASSWORD=dinamo
POSTGRES_DB=dinamo_marketing

# --- Redis ---
REDIS_URL=redis://localhost:6380/0
CELERY_BROKER_URL=redis://localhost:6380/1
CELERY_RESULT_BACKEND=redis://localhost:6380/2

# --- API Server ---
API_HOST=0.0.0.0
API_PORT=8001
API_RELOAD=true
API_LOG_LEVEL=info

# --- Mock System (set to false to use real APIs) ---
DM_USE_MOCK_APIS=true

# --- Individual API Overrides (only if DM_USE_MOCK_APIS=false) ---
DM_USE_REAL_CLAUDE=false
DM_USE_REAL_META=false
DM_USE_REAL_TIKTOK=false
DM_USE_REAL_YOUTUBE=false
DM_USE_REAL_GA4=false
DM_USE_REAL_SPORTS_DATA=false
DM_USE_REAL_BUFFER=false
DM_USE_REAL_IMAGE_GEN=false
DM_USE_REAL_TRENDS=false

# --- Claude / Anthropic API ---
ANTHROPIC_API_KEY=sk-ant-xxxxx

# --- Meta (Facebook + Instagram) ---
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_PAGE_ID=
META_INSTAGRAM_ACCOUNT_ID=

# --- TikTok Business API ---
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_ADVERTISER_ID=

# --- YouTube Data API ---
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=

# --- Google Analytics 4 ---
GA4_PROPERTY_ID=
GA4_CREDENTIALS_JSON=

# --- SportRadar ---
SPORTRADAR_API_KEY=

# --- TheSportsDB ---
THESPORTSDB_API_KEY=123

# --- Buffer ---
BUFFER_ACCESS_TOKEN=
BUFFER_CLIENT_ID=
BUFFER_CLIENT_SECRET=

# --- Image Generation ---
OPENAI_API_KEY=
STABILITY_API_KEY=

# --- Email Notifications ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFICATION_EMAIL=

# --- App Settings ---
APP_SECRET_KEY=change-this-to-a-random-secret-key
APP_NAME="Dinamo Marketing Platform"
CORS_ORIGINS=http://localhost:3001
